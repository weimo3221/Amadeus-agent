{
  "name": "amadeus-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop Live2D interactive agent",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:desktop\"",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "typecheck": "npm --workspace packages/shared run typecheck && npm --workspace apps/server run typecheck && npm --workspace apps/desktop run typecheck",
    "test": "echo \"TODO: run tests\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
